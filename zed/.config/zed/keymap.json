[
  // =============================================================================
  // Zed Keybindings
  // =============================================================================
  // Designed to match tmux/Neovim muscle memory
  // =============================================================================

  // jk to escape insert mode (common vim customization)
  {
    "context": "vim_mode == insert",
    "bindings": {
      "j k": "vim::NormalBefore"
    }
  },

  // Pane navigation - matches tmux/Neovim Ctrl+hjkl
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-l": "workspace::ActivatePaneRight"
    }
  },

  // Vim-sneak - jump to two-character sequence (replaces deprecated enable_vim_sneak setting)
  {
    "context": "vim_mode == normal || vim_mode == visual",
    "bindings": {
      "s": "vim::PushSneak",
      "shift-s": "vim::PushSneakBackward"
    }
  },

  // Split windows - match Neovim ss/sv
  // Note: Zed handles key sequences - ss/sv work alongside single s for sneak
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "s s": "pane::SplitRight",
      "s v": "pane::SplitDown"
    }
  },

  // Buffer navigation with Shift+h/l
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "shift-h": "pane::ActivatePreviousItem",
      "shift-l": "pane::ActivateNextItem",
      "shift-q": "pane::CloseActiveItem"
    }
  },

  // Leader-style bindings (space as pseudo-leader)
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "space space": "file_finder::Toggle",
      "space /": "search::SelectAllMatches",
      "space e": "project_panel::ToggleFocus",
      "space b d": "pane::CloseActiveItem"
    }
  },

  // Project panel vim navigation
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "j": "menu::SelectNext",
      "k": "menu::SelectPrevious",
      "l": "project_panel::Open",
      "h": "project_panel::CollapseSelectedEntry",
      "o": "project_panel::Open"
    }
  }
]
