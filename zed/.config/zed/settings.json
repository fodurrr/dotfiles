{
  // =============================================================================
  // Zed Editor Settings
  // =============================================================================
  // Vim mode with Catppuccin Mocha theme
  // Keybindings match tmux/Neovim for unified muscle memory
  // =============================================================================

  // Vim mode - essential
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "always",
    "use_smartcase_find": true,
  },

  // Line numbers - match Neovim (use string enum, not boolean)
  "relative_line_numbers": "enabled",

  // UI - clean vim experience
  "scrollbar": { "show": "never" },
  "cursor_blink": false,
  "scroll_beyond_last_line": "off",

  // Session - restore all windows/tabs on startup (use Cmd+Q to quit, not red X)
  "restore_on_startup": "last_session",

  // Theme - Catppuccin Mocha (matches Ghostty, tmux, Neovim)
  // Use object format for proper light/dark mode support
  "theme": {
    "mode": "dark",
    "dark": "Catppuccin Mocha - No Italics",
    "light": "One Light",
  },
  "icon_theme": "Catppuccin Mocha",

  // Auto-install required extensions on first run
  "auto_install_extensions": {
    "catppuccin": true,
    "catppuccin-icons": true,
    "elixir": true,
    "ruby": true,
    "toml": true,
    "html": true,
    "emmet": true,
    "sql": true,
    "dockerfile": true,
    "make": true,
    "git-firefly": true,
    "unocss": true,
    "log": true
  },

  // Language configurations
  "languages": {
    "Elixir": {
      "language_servers": ["elixir-ls"],
      "format_on_save": "on"
    },
    "HEEX": {
      "language_servers": [
        "elixir-ls",
        "!tailwindcss-language-server",
        "unocss",
        "emmet-language-server"
      ]
    }
  },

  // LSP settings
  "lsp": {
    "elixir-ls": {
      "settings": {
        "dialyzerEnabled": false,
        "fetchDeps": false,
        "suggestSpecs": true
      }
    }
  },

  // Vim mode indicator colors - fix visibility on Catppuccin Mocha
  // Per-mode background + foreground from schema.rs (vim.mode.text doesn't exist)
  "theme_overrides": {
    "Catppuccin Mocha": {
      "vim.normal.background": "#89b4fa",
      "vim.normal.foreground": "#1e1e2e",
      "vim.insert.background": "#a6e3a1",
      "vim.insert.foreground": "#1e1e2e",
      "vim.visual.background": "#cba6f7",
      "vim.visual.foreground": "#1e1e2e",
      "vim.visual_line.background": "#cba6f7",
      "vim.visual_line.foreground": "#1e1e2e",
      "vim.visual_block.background": "#cba6f7",
      "vim.visual_block.foreground": "#1e1e2e",
      "vim.replace.background": "#f38ba8",
      "vim.replace.foreground": "#1e1e2e",
    },
  },
  "experimental.theme_overrides": {
    "syntax": {
      // Headings
      "markup.heading": { "color": "#f5e0dc", "font_weight": 700 },
      "markup.heading.1": { "color": "#f38ba8" },
      "markup.heading.2": { "color": "#eba0ac" },
      "markup.heading.3": { "color": "#fab387" },
      "markup.heading.4": { "color": "#f9e2af" },
      "markup.heading.5": { "color": "#a6e3a1" },
      "markup.heading.6": { "color": "#89b4fa" },

      // Emphasis
      "markup.bold": { "color": "#f38ba8", "font_weight": 700 },
      "markup.italic": { "color": "#89b4fa", "font_style": "italic" },

      // Links
      "markup.link": { "color": "#89dceb" },
      "markup.link.url": { "color": "#74c7ec" },

      // Code
      "markup.raw": { "color": "#a6e3a1" },
      "markup.raw.inline": { "color": "#a6e3a1" },

      // Lists
      "markup.list": { "color": "#cba6f7" },
      "markup.list.bullet": { "color": "#94e2d5" },
      "markup.list.numbered": { "color": "#fab387" },

      // Blockquotes
      "markup.quote": { "color": "#bac2de" },

      // Horizontal rule
      "markup.separator": { "color": "#45475a" },

      // Tables
      "markup.table": { "color": "#f9e2af" }
    }
  },

  // Font - match Ghostty
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_size": 16,
  "ui_font_size": 16,
  "ui_font_family": "JetBrainsMono Nerd Font",
  "agent_ui_font_size": 16,
  "agent_buffer_font_size": 16,

  // Terminal - match shell setup
  "terminal": {
    "shell": "system",
    "font_family": "JetBrainsMono Nerd Font",
    "font_size": 16,
  },

  // Panels - right-side project panel
  "project_panel": {
    "dock": "left",
  },
}
