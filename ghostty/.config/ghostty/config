# --- Appearance ---
font-family = "JetBrainsMono Nerd Font"
font-size = 16

# Padding
window-padding-x = 12
window-padding-y = 10
window-padding-balance = true

# Colors / theme
theme = "Catppuccin Mocha"
split-divider-color = #f9e2af

# Cursor
cursor-style = block
cursor-style-blink = false

# Behaviour
copy-on-select = true
scrollback-limit = 10485760
quit-after-last-window-closed = true

# Shell integration for sudo (required for sandvault TTY allocation)
shell-integration-features = sudo
