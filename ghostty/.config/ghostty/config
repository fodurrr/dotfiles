# --- Appearance ---
font-family = "JetBrains Mono"
font-size = 13

# Padding
window-padding-x = 12
window-padding-y = 10
window-padding-balance = true

# Colors / theme
theme = "Catppuccin Mocha"

# Cursor
cursor-style = block
cursor-style-blink = false

# Behaviour
copy-on-select = true
scrollback-limit = 10485760
