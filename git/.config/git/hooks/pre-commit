#!/bin/bash
# =============================================================================
# Global Pre-commit Hook - Protect Main Branches
# =============================================================================
# This hook prevents direct commits to main/master branches.
# Part of the AI Agent Safety setup - forces use of feature branches + PRs.
#
# Location: ~/.config/git/hooks/pre-commit (via stow)
# To bypass (emergency only): git commit --no-verify
# =============================================================================

# Get current branch name
branch=$(git symbolic-ref --short HEAD 2>/dev/null)

# List of protected branches
protected_branches=("main" "master" "production" "prod")

# Check if current branch is protected
for protected in "${protected_branches[@]}"; do
    if [[ "$branch" == "$protected" ]]; then
        echo ""
        echo "========================================"
        echo "  BLOCKED: Direct commit to '$branch'"
        echo "========================================"
        echo ""
        echo "  Protected branches require pull requests."
        echo ""
        echo "  Create a feature branch instead:"
        echo "    git checkout -b feature/my-change"
        echo "    git commit -m \"your message\""
        echo "    git push -u origin feature/my-change"
        echo "    gh pr create"
        echo ""
        echo "  Emergency bypass (not recommended):"
        echo "    git commit --no-verify"
        echo ""
        exit 1
    fi
done

# Allow commit on non-protected branches
exit 0
