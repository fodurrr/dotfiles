[user]
    name = Peter Fodor
    email = fodurrr@users.noreply.github.com
    signingkey = ~/.ssh/id_ed25519.pub

[core]
    editor = nvim
    excludesfile = ~/.gitignore_global
    # Fix filename casing issues on macOS
    ignorecase = false
    # Global hooks path - protects main branches from direct commits
    hooksPath = ~/.config/git/hooks

[init]
    defaultBranch = main

[pull]
    # Keep history linear and clean
    rebase = true
    # Prevent accidental merge commits - only fast-forward
    ff = only

[push]
    # Automatically set upstream branch on push (Huge time saver!)
    autoSetupRemote = true

[credential]
    # Use macOS Keychain to store passwords/tokens
    helper = osxkeychain

[rerere]
    # "Reuse Recorded Resolution" - Remembers how you fixed a merge conflict
    # so you don't have to fix the same one twice.
    enabled = true

[alias]
    # Common shortcuts
    # s = status
    # co = checkout
    # br = branch
    # ci = commit
    st = status
    unstage = reset HEAD --
    last = log -1 HEAD
    # Pretty log graph
    lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit

[commit]
    # Sign commits using SSH key (more modern than GPG)
    gpgSign = true

[gpg]
    # Use SSH for signing instead of GPG
    format = ssh

[gpg "ssh"]
    # Default ssh-agent works automatically if your signing key is loaded.
    # Optional: Uncomment ONE of the following for enhanced setups:
    # For 1Password: program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"
    # For macOS ssh-agent verification: allowedSignersFile = ~/.ssh/allowed_signers
