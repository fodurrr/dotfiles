#!/bin/bash
# =============================================================================
# SketchyBar Configuration
# =============================================================================
# Catppuccin Mocha theme with JetBrains Mono Nerd Font
# Layout: Apple+App (left) | Workspaces+Help (center) | Stats+Date (right)
# =============================================================================

PLUGIN_DIR="$CONFIG_DIR/plugins"
ITEM_DIR="$CONFIG_DIR/items"

# Load colors and icons
source "$CONFIG_DIR/colors.sh"
source "$CONFIG_DIR/icons.sh"

# =============================================================================
# Start System Stats Provider (sketchybar-system-stats)
# =============================================================================
# Kill any existing instance and start fresh
killall sketchybar-system-stats 2>/dev/null
sketchybar-system-stats &

# =============================================================================
# Bar Appearance
# =============================================================================
bar=(
    height=40
    blur_radius=30
    position=top
    sticky=on
    padding_left=10
    padding_right=10
    color=$BAR_COLOR
    corner_radius=9
    y_offset=5
    margin=10
    shadow=on
)

sketchybar --bar "${bar[@]}"

# =============================================================================
# Default Item Settings
# =============================================================================
defaults=(
    icon.font="JetBrainsMono Nerd Font:Bold:14.0"
    icon.color=$ICON_COLOR
    label.font="JetBrainsMono Nerd Font:Medium:13.0"
    label.color=$TEXT_COLOR
    label.align=center
    background.color=$ITEM_BG_COLOR
    background.corner_radius=5
    background.height=24
    padding_left=5
    padding_right=5
    label.padding_left=4
    label.padding_right=4
    icon.padding_left=4
    icon.padding_right=4
)

sketchybar --default "${defaults[@]}"

# =============================================================================
# Events (register BEFORE items subscribe to them)
# =============================================================================
sketchybar --add event aerospace_workspace_change
sketchybar --add event system_stats           # From sketchybar-system-stats

# =============================================================================
# Left Items
# =============================================================================
source "$ITEM_DIR/apple.sh"
source "$ITEM_DIR/preferences.sh"
source "$ITEM_DIR/activity.sh"

# Bracket around system controls (Apple, Preferences, Activity)
sketchybar --add bracket system_controls apple.logo preferences activity \
    --set system_controls \
        background.color=$SURFACE0 \
        background.corner_radius=5 \
        background.height=28

# Spacer between system_controls and front_app
sketchybar --add item spacer.left1 left \
    --set spacer.left1 \
        width=10 \
        background.drawing=off \
        icon.drawing=off \
        label.drawing=off

source "$ITEM_DIR/front_app.sh"

# Bracket around front app (separate from system controls)
sketchybar --add bracket front_app_bracket front_app \
    --set front_app_bracket \
        background.color=$SURFACE0 \
        background.corner_radius=5 \
        background.height=28

# =============================================================================
# Center Items
# =============================================================================
source "$ITEM_DIR/lock.sh"

# Spacer between lock and workspaces
sketchybar --add item spacer.center1 center \
    --set spacer.center1 \
        width=10 \
        background.drawing=off \
        icon.drawing=off \
        label.drawing=off

source "$ITEM_DIR/aerospace.sh"

# Spacer between workspaces and tools
sketchybar --add item spacer.center2 center \
    --set spacer.center2 \
        width=10 \
        background.drawing=off \
        icon.drawing=off \
        label.drawing=off

source "$ITEM_DIR/keyboard.sh"
source "$ITEM_DIR/help.sh"

# Bracket around tools (keyboard + help)
sketchybar --add bracket tools_bracket keyboard help \
    --set tools_bracket \
        background.color=$SURFACE0 \
        background.corner_radius=5 \
        background.height=28

# =============================================================================
# Right Items (added right-to-left, so calendar first = rightmost)
# =============================================================================
source "$ITEM_DIR/calendar.sh"

# Spacer between calendar and stats bracket
sketchybar --add item spacer.right1 right \
    --set spacer.right1 \
        width=10 \
        background.drawing=off \
        icon.drawing=off \
        label.drawing=off

source "$ITEM_DIR/network.sh"
source "$ITEM_DIR/battery.sh"
source "$ITEM_DIR/volume.sh"
source "$ITEM_DIR/memory.sh"
source "$ITEM_DIR/cpu.sh"

# Bracket around all stats (CPU, Memory, Volume, Battery, Network)
sketchybar --add bracket stats cpu memory volume battery network \
    --set stats \
        background.color=$SURFACE0 \
        background.corner_radius=5 \
        background.height=28

# =============================================================================
# Finalize
# =============================================================================
sketchybar --update

# Trigger initial workspace highlight
FOCUSED=$(aerospace list-workspaces --focused 2>/dev/null || echo "1")
sketchybar --trigger aerospace_workspace_change FOCUSED_WORKSPACE="$FOCUSED"
